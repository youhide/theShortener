{
  "name": "theshortener",
  "version": "1.2.0",
  "description": "String Shortener",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "theshortener": "cli.js"
  },
  "scripts": {
    "install": "node-gyp-build",
    "build": "node-gyp configure && node-gyp build",
    "prebuild": "prebuildify --napi --strip",
    "test": "ava",
    "bench": "node bench.js"
  },
  "dependencies": {
    "node-addon-api": "^8.0.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "ava": "^6.2.0",
    "prebuildify": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/youhide/theShortener.git"
  },
  "keywords": [
    "url-shortener",
    "hash",
    "sha256",
    "base62",
    "nodejs-addon",
    "native",
    "napi"
  ],
  "license": "MIT",
  "author": "YouHide"
}
